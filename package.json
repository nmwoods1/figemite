{
  "name": "figemite-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -w @figemite/client run dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm -w @figemite/client run test:e2e",
    "test:e2e:visual": "npm -w @figemite/client run test:e2e:visual",
    "build:static": "node packages/client/scripts/build-static.mjs",
    "license:audit": "node scripts/license-audit.mjs",
    "audit:refs": "node scripts/prepublish-audit.mjs",
    "oracle": "node scripts/oracle.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.2.6"
  }
}
