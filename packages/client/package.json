{
  "name": "@figemite/client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "predev": "tsc -b ../shared ../server --force",
    "dev": "concurrently -k -n tsc,vite -c gray,cyan \"tsc -b ../shared ../server --watch --preserveWatchOutput\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:visual": "playwright test --project=chromium-visual"
  },
  "dependencies": {
    "@figemite/shared": "*",
    "@tiptap/extension-list": "^3.27.2",
    "@tiptap/markdown": "^3.27.2",
    "@tiptap/react": "^3.27.2",
    "@tiptap/starter-kit": "^3.27.2",
    "@xyflow/react": "^12.11.1",
    "lucide-react": "^1.23.0",
    "perfect-freehand": "^1.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "y-indexeddb": "^9.0.12",
    "y-websocket": "^2.1.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@figemite/server": "*",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.3",
    "jsdom": "^29.1.1",
    "vite": "^8.1.3"
  }
}
